
design.sv
module half_adder(input a,b, output s,c );
    assign s= (a ^ b) ;
    assign c= (a & b);
endmodule


testbench.sv
module tb;
    reg a,b;
    wire s,c;
    half_adder u1(a,b,s,c);
    initial begin
        $dumpvars(0, tb);
        $monitor($time,"|  a=%b b=%b sum:-> s=%b  carry:-> c=%b|",a,b,s,c);
        a=0;b=0; #10;
        a=0;b=1; #10;
        a=1;b=0; #10;
        a=1;b=1; #10;
        $finish ;
    end
endmodule
