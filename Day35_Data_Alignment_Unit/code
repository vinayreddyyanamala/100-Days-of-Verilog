Design code :
module data_alignment_unit #(parameter N = 8)
  (
    input  [N-1:0] A,
    input  [2:0] Shift,
    input  [2:0] Mode,
    output reg [N-1:0] Y);
always @(*) begin
 
  case(Mode)
3'b000 : Y = A << Shift;                       // Left Shift
3'b001 : Y = A >> Shift;                       // Right Shift
3'b010 : Y = (A << Shift) | (A >> (N-Shift)); // Rotate Left
3'b011 : Y = (A >> Shift) | (A << (N-Shift)); // Rotate Right
3'b100 : Y = {A[N-2:0],A[N-1]};               // Rotate Left by 1
3'b101 : Y = {A[0],A[N-1:1]};                 // Rotate Right by 1
3'b110 : Y = A;                               // Pass Through
3'b111 : Y = ~A;                              // Bitwise NOT
default: Y = A;
 
  endcase
end

endmodule


