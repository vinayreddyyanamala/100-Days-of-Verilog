module tb;
reg  [7:0] A;
reg  [2:0] Shift;
reg  [2:0] Mode;
wire [7:0] Y;
integer i,j;
  data_alignment_unit #(8) dut (A,Shift,Mode,Y);
initial begin
    $dumpvars(1,tb);
    A = 8'b10110010;
    for(j=0; j<8; j=j+1)
    begin  Mode = j;
      if(j < 4)  begin
            for(i=0; i<4; i=i+1)
            begin Shift = i;#10;
                case(Mode)
            0: $display("T=%0t | LEFT SHIFT   | Shift=%0d | A=%b (%0d) | Y=%b (%0d)",
                                $time,Shift,A,A,Y,Y);
            1: $display("T=%0t | RIGHT SHIFT  | Shift=%0d | A=%b (%0d) | Y=%b (%0d)", 
                                $time,Shift,A,A,Y,Y);          
            2: $display("T=%0t | ROTATE LEFT  | Shift=%0d | A=%b (%0d) | Y=%b (%0d)",
                      $time,Shift,A,A,Y,Y);
            3: $display("T=%0t | ROTATE RIGHT | Shift=%0d | A=%b (%0d) | Y=%b (%0d)",
                                $time,Shift,A,A,Y,Y);
                endcase
            end end
else        begin
            Shift = 0; #10;
            case(Mode)
                4: $display("T=%0t | ROL BY 1     | A=%b (%0d) | Y=%b (%0d)",
                            $time,A,A,Y,Y);
                5: $display("T=%0t | ROR BY 1     | A=%b (%0d) | Y=%b (%0d)",
                            $time,A,A,Y,Y);
              6: $display("T=%0t | PASS THROUGH | A=%b (%0d) | Y=%b (%0d)",  	 
                          $time,A,A,Y,Y);
                7: $display("T=%0t | BITWISE NOT  | A=%b (%0d) | Y=%b (%0d)",
                            $time,A,A,Y,Y);
            endcase
       end end
    $finish;
end
endmodule
