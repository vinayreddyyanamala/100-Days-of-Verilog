Design code
module mux4to1 #(parameter N = 4)
(
    input  [N-1:0] D0,
    input  [N-1:0] D1,
    input  [N-1:0] D2,
    input  [N-1:0] D3,
    input  [1:0]   S,
    output reg [N-1:0] Y);
always @(*) begin
    case(S)
        2'b00: Y = D0;
        2'b01: Y = D1;
        2'b10: Y = D2;
        2'b11: Y = D3;
        default: Y =0;
    endcase
end
endmodule

  
