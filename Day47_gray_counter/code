gray_counter.v
module gray_counter #(
    parameter N = 3
)(
    input              clk,
    input              rst_n,      // Active low reset
    output reg [N-1:0] gray
);

reg [N-1:0] binary;    // Internal binary counter

// Binary Counter
always @(posedge clk or negedge rst_n) begin
    if (!rst_n)
        binary <= {N{1'b0}};
    else
        binary <= binary + 1'b1;
end

// Binary to Gray Conversion
always @(*) begin
    gray = binary ^ (binary >> 1);
end

endmodule
tb_gray_counter.v
`timescale 1ns/1ps

module tb_gray_counter;

parameter N = 3;

reg clk, rst_n;
wire [N-1:0] gray;

// DUT Instantiation
gray_counter #(N) dut (
    .clk   (clk),
    .rst_n (rst_n),
    .gray  (gray)
);

// Clock Generation (100MHz)
initial clk = 0;
always #5 clk = ~clk;      // 10ns period

// Stimulus
initial begin
    rst_n = 0;             // Assert reset
    #12;
    rst_n = 1;             // De-assert reset

    #200;
    $finish;
end

// Monitor
initial begin
    $display("Time\tRST_N\tBINARY\tGRAY");
    $monitor("%0t\t%b\t%b\t%b", $time, rst_n, dut.binary, gray);
end

endmodule
